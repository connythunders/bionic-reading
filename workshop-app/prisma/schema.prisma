generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Submission {
  id        Int      @id @default(autoincrement())
  teamName  String
  createdAt DateTime @default(now())
  answers   Answer[]
}

model Answer {
  id           Int        @id @default(autoincrement())
  questionId   String
  answerText   String
  submission   Submission @relation(fields: [submissionId], references: [id])
  submissionId Int
}
