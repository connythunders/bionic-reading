# Anthropic API – server-side endast. Lägg ALDRIG denna i klientkoden.
# Skapa nyckel på https://console.anthropic.com och lägg in den som
# Environment Variable i Vercel (Project Settings → Environment Variables).
ANTHROPIC_API_KEY=sk-ant-...

# Valfritt: model-id. Standard sätts i koden. Kontrollera giltigt id på
# https://docs.claude.com innan driftsättning om du vill byta modell.
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Valfritt: sätt till "0" för att stänga av live-anrop mot Skolverket och
# alltid använda den medföljande exempeldatan (bra för utveckling offline).
# SKOLVERKET_LIVE=1
