# SMTP-konfiguration (för e-postnotiser)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=din@gmail.com
SMTP_PASS=ditt-app-lösenord
FROM_EMAIL=Riksdagsbevakaren <din@gmail.com>

# Databas
DB_PATH=./data/riksdag.db

# Server
PORT=3000
BASE_URL=http://localhost:3000

# Säkerhetsnyckel för manuell uppdatering
REFRESH_KEY=hemlig-nyckel-för-manuell-refresh

# Valfritt: Anthropic API-nyckel för AI-sammanfattningar
# ANTHROPIC_API_KEY=sk-ant-...
